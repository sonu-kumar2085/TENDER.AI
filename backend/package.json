{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run start:api\" \"npm run start:ml\"",
    "start:api": "node server.js",
    "start:ml": "cd ML && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ml\"",
    "dev:api": "nodemon server.js",
    "dev:ml": "cd ML && python -m uvicorn main:app --reload --port 8000",
    "install:backend": "npm install && python -m pip install -r ML/requirements.txt",
    "seed": "node seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
